<Window x:Class="ClearOffice.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClearOffice Setup" Height="550" Width="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#F0F0F0" FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#1A1A2E" Padding="30,25">
            <StackPanel>
                <TextBlock Text="ClearOffice" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                <TextBlock Text="Installation Wizard" FontSize="14" Foreground="#8888AA" HorizontalAlignment="Center" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <StackPanel Grid.Row="1" Margin="30,20">
            <!-- Приложения -->
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Applications to install:" FontSize="14" FontWeight="SemiBold" Foreground="#333355" Margin="0,0,0,12"/>

                    <CheckBox x:Name="ClearWordCheck" IsChecked="True" Margin="0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📝" FontSize="20" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="ClearWord" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Text editor with .clew format" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                    </CheckBox>

                    <CheckBox x:Name="ClearPaintCheck" IsChecked="True" Margin="0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎨" FontSize="20" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="ClearPaint" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Drawing tool with .clep format" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                    </CheckBox>

                    <CheckBox x:Name="ClearDocCheck" IsChecked="True" Margin="0,4">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📖" FontSize="20" Margin="0,0,8,0"/>
                            <StackPanel>
                                <TextBlock Text="ClearDoc" FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="Universal file viewer" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                        </StackPanel>
                    </CheckBox>
                </StackPanel>
            </Border>

            <!-- Папка установки -->
            <Border Background="White" CornerRadius="8" Padding="20" BorderBrush="#E0E0E0" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Installation folder:" FontSize="13" FontWeight="SemiBold" Foreground="#333355" Margin="0,0,0,8"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox x:Name="PathBox" Grid.Column="0" Height="34" VerticalAlignment="Center"
                                 Background="#F8F8FA" BorderBrush="#D0D0D8" IsReadOnly="True"
                                 Text="C:\Program Files\ClearOffice" FontSize="13"/>

                        <Button x:Name="BrowseBtn" Grid.Column="1" Content="Browse" Width="80" Height="34"
                                Margin="8,0,0,0" Cursor="Hand" Click="BrowseBtn_Click">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="#F0F0F5"/>
                                    <Setter Property="BorderBrush" Value="#D0D0D8"/>
                                    <Setter Property="Foreground" Value="#444466"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#E0E0EE"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="White" Padding="20,15" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ProgressBar x:Name="ProgressBar" Width="200" Height="6" Minimum="0" Maximum="100" Value="0"
                                 Visibility="Collapsed" Margin="0,0,10,0"/>
                    <TextBlock x:Name="StatusText" Text="" FontSize="12" Foreground="#666688" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelBtn" Content="Cancel" Width="90" Height="36"
                            Background="#F0F0F5" BorderBrush="#D0D0D8" Foreground="#666688"
                            Cursor="Hand" FontSize="13" Margin="0,0,10,0"/>

                    <Button x:Name="InstallBtn" Content="Install" Width="120" Height="36"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand" Click="InstallBtn_Click">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#4488FF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#3366DD"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Background" Value="#AABBCC"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>